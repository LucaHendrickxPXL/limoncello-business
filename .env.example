DATABASE_URL=postgresql://postgres:postgres@localhost:5434/limoncello_business
AUTH_SETUP_KEY=vervang-door-een-lange-geheime-setup-key
AUTH_PASSWORD_PEPPER=vervang-door-een-lange-geheime-pepper

# Alleen nodig als je `docker compose up` lokaal voor de webcontainer gebruikt.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=5000
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DB=limoncello_business
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
